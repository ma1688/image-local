# 复制为根目录 .env 并按需修改
# docker compose 会自动读取该文件

# ============= Backend =============
APP_DATA_DIR=/app/data

# celery | asyncio
TASK_BACKEND=celery

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 留空则首次启动自动生成并写入 backend/data/.fernet_key
SECRET_FERNET_KEY=

ALLOW_ANY_DIR_SCAN=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5178

# ============= Frontend =============
VITE_API_BASE=/api
