# 复制为根目录 .env 并按需修改
# docker compose 会自动读取该文件

# ============= Backend =============
APP_DATA_DIR=/app/data
PIP_INDEX_URL=https://pypi.org/simple

# celery | asyncio
TASK_BACKEND=celery

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 留空则首次启动自动生成并写入 backend/data/.fernet_key
SECRET_FERNET_KEY=
# 允许扫描任何目录
ALLOW_ANY_DIR_SCAN=true
# 日志级别
LOG_LEVEL=INFO
# 跨域
CORS_ORIGINS=http://localhost:5178
# celery 并发数
CELERY_CONCURRENCY=4

# 宿主机端口映射；compose 内部仍分别使用 8787 / 5173
BACKEND_PORT=8787
FRONTEND_PORT=5178

# ============= Frontend =============
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
VITE_API_BASE=/api
VITE_BACKEND_TARGET=http://backend:8787
